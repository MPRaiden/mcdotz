env = EDITOR=/opt/homebrew/bin/nvim
env = VISUAL=/opt/homebrew/bin/nvim

font-family = IoskeleyMono Nerd Font
font-size = 12
font-thicken = true
font-thicken-strength = 175

# theme = light:TokyoNight Day,dark:TokyoNight Moon
theme = light:Rose Pine Dawn,dark:Rose Pine Moon

cursor-style-blink = true
mouse-hide-while-typing = true
shell-integration-features = no-cursor,no-sudo,title

macos-titlebar-style = tabs

scrollback-limit = 10000000
confirm-close-surface = false
copy-on-select = true
keybind = cmd+q=quit

window-padding-x = 10
window-padding-y = 10

maximize = true

keybind = ctrl+t=new_tab
keybind = ctrl+[=previous_tab
keybind = ctrl+]=next_tab
keybind = ctrl+q=close_tab
keybind = ctrl+s=start_search

window-save-state = never
